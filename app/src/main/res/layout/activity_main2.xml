<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <Button
        android:id="@+id/sosBtn"
        android:layout_width="200dp"
        android:layout_height="60dp"
        android:text="SOS"
        android:textSize="20sp"

        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/policeBtn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/policeBtn"
        android:layout_width="200dp"
        android:layout_height="60dp"
        android:text="POLICE"

        app:layout_constraintTop_toBottomOf="@id/sosBtn"
        app:layout_constraintBottom_toTopOf="@id/hospitalBtn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/hospitalBtn"
        android:layout_width="200dp"
        android:layout_height="60dp"
        android:text="HOSPITAL"

        app:layout_constraintTop_toBottomOf="@id/policeBtn"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>